<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard - StudentSpace</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet" />
  <link href="/css/admin.css" rel="stylesheet" />
</head>

<body>
  <div class="app" id="app">
    <div class="sidebar" id="sidebar">
      <h2>MyStudentSpace</h2>

      <div class="menu">
        <a class="active" id="link-dashboard" onclick="switchTab('dashboard')" style="cursor: pointer;">DASHBOARD</a>
        <div class="menu-title">ACADEMIC</div>
        <a id="link-subjects" onclick="switchTab('subjects')" style="cursor: pointer;">Subjects</a>
        <a id="link-results" onclick="switchTab('results')" style="cursor: pointer;">Results</a>
        <div class="menu-title">COMMUNICATION</div>
        <a id="link-announcements" onclick="switchTab('announcements')" style="cursor: pointer;">Announcements</a>
        <div class="menu-title">STUDENT UPDATES</div>
        <a id="link-updates" onclick="switchTab('updates')" style="cursor: pointer;">Next Exam</a>
        <a id="link-classes" onclick="switchTab('classes')" style="cursor: pointer;">Classes & Events</a>
        <div class="menu-title">ACCOUNT</div>
        <a href="/login" onclick="localStorage.removeItem('token')" style="color: #e02424;"><i class="bx bx-log-out"></i> Log Out</a>
      </div>
    </div>
    <div class="main">
      <div class="header admin-header">
        <div class="header-left">
          <button class="toggle-btn" onclick="toggleSidebar()">☰</button>
          <h3 class="page-title">Dashboard Overview</h3>
        </div>

        <div class="user-profile">
          <div class="avatar" id="avatarLetter">
            <%= user && user.name ? user.name.charAt(0).toUpperCase() : "A" %>
          </div>
          <span id="teacher-name">
            <%= user && user.name || "Admin" %>
          </span>
        </div>
      </div>

      <div id="dashboard" class="content-section">
        <div class="dashboard admin-dashboard">
          <div class="cards admin-cards">
          <div class="card">
            <span>Total Subjects</span>
            <h2><%= typeof subjects !== 'undefined' ? subjects.length : 0 %></h2>
          </div>
          <div class="card">
            <span>Total Students</span>
            <h2><%= typeof totalStudents !== 'undefined' ? totalStudents : 79 %></h2>
          </div>
          <div class="card">
            <span>Average Attendance</span>
            <h2><%= typeof avgAttendance !== 'undefined' ? avgAttendance + '%' : '85%' %></h2>
          </div>
        </div>
        
        <div class="panel-column">
          <div class="panel">
            <h3 class="panel-title"><i class="bx bx-edit"></i> Update Student Attendance</h3>
            <form class="admin-form" id="attendanceForm">
              <div class="input-group">
                <label>Roll No.</label>
                <input type="text" id="roll" placeholder="e.g. 2410991138" required />
              </div>
              <div class="input-group">
                <label>Subjects</label>
                <select id="subjectselect" class="subject-select" required>
                  <option value="">Select Subject</option>
                  <% if (typeof subjects !== 'undefined' && subjects.length > 0) { %>
                    <% subjects.forEach(sub => { %>
                      <option value="<%= sub.name %>"><%= sub.name %></option>
                    <% }) %>
                  <% } %>
                </select>
              </div>
              <div class="input-group">
                <label>Attendance</label>
                <input type="number" id="percent" placeholder="75" required />
              </div>
              <button type="submit" class="btn-primary">
                <i class="bx bx-save"></i> Update Database
              </button>
              <p id="form-msg" style="margin-top: 10px; color: #4CAF50; font-weight: bold;"></p>
            </form>
          </div>

        </div>

        <div class="panel-column">
          <div class="panel">
            <div class="panel-header">
              <h3 class="panel-title"><i class="bx bx-bar-chart-alt-2"></i> Attendance Analytics</h3>
              <select class="filter-select" id="attendanceFilter">
                <option value="semester" selected>By Subject</option>
                <option value="weekly">This Week</option>
                <option value="monthly">This Month</option>
              </select>
            </div>
            <div style="position: relative; height: 280px; width: 100%;">
              <canvas id="attendanceChart"></canvas>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div id="subjects" class="content-section" style="display: none;">
      <div class="dashboard admin-dashboard" style="display: block; padding-top: 24px;">
        <div class="panel">
          <div class="panel-header">
            <h3 class="panel-title"><i class="bx bx-book"></i> Manage Subjects</h3>
            <button class="btn-primary" style="padding: 6px 12px; margin-top: 0;" onclick="openModal()"><i class="bx bx-plus"></i> Add Subject</button>
          </div>
          
          <table style="width: 100%;">
            <thead>
              <tr>
                <th>Course Code</th>
                <th>Course Name</th>
                <th>Credits</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (subjects && subjects.length > 0) { %>
                <% subjects.forEach(sub => { %>
                  <tr>
                    <td><%= sub.code %></td>
                    <td><%= sub.name %></td>
                    <td><%= sub.credits %></td>
                    <td>
                      <div class="action-btns">
                        <button class="btn-delete" onclick="deleteSubject('<%= sub._id %>')"><i class="bx bx-trash"></i></button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="4" style="text-align: center;">No subjects available</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  <div id="results" class="content-section" style="display: none;">
    <div class="dashboard admin-dashboard" style="display: block; padding-top: 24px;">
      <div class="panel">
        <div class="panel-header">
          <h3 class="panel-title"><i class="bx bx-edit"></i> Manage Student Results</h3>
          <button class="btn-primary" style="padding: 6px 12px; margin-top: 0;" onclick="openResultModal()"><i class="bx bx-plus"></i> Add/Update Result</button>
        </div>
        
        <table style="width: 100%;">
          <thead>
            <tr>
              <th>Roll No.</th>
              <th>Name</th>
              <th>Sem</th>
              <th>Subject</th>
              <th>Marks</th>
              <th>Grade</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (typeof allResults !== 'undefined' && allResults.length > 0) { %>
              <% allResults.forEach(res => { %>
                <tr>
                  <td><%= res.roll %></td>
                  <td><%= res.name %></td>
                  <td><%= res.sem || "N/A" %></td>
                  <td><%= res.subject %></td>
                  <td><%= res.marks %></td>
                  <td><%= res.grade || "N/A" %></td>
                  <td>
                    <div class="action-btns">
                      <button class="btn-delete" onclick="deleteResult('<%= res.dashId %>', '<%= res._id %>')"><i class="bx bx-trash"></i></button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" style="text-align: center;">No results available</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div id="announcements" class="content-section" style="display: none;">
    <div class="dashboard admin-dashboard" style="display: block; padding-top: 24px;">
      <div class="panel">
        <div class="panel-header">
          <h3 class="panel-title"><i class="bx bx-bell"></i> Manage Announcements</h3>
          <button class="btn-primary" style="padding: 6px 12px; margin-top: 0;" onclick="openAnnouncementModal()"><i class="bx bx-plus"></i> Add Announcement</button>
        </div>
        
        <table style="width: 100%;">
          <thead>
            <tr>
              <th>Title</th>
              <th>Content</th>
              <th>Date/Time</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (typeof announcements !== 'undefined' && announcements.length > 0) { %>
              <% announcements.forEach(ann => { %>
                <tr>
                  <td><%= ann.title %></td>
                  <td><%= ann.text %></td>
                  <td><%= ann.time %></td>
                  <td>
                    <div class="action-btns">
                      <button class="btn-delete" onclick="deleteAnnouncement('<%= ann._id %>')"><i class="bx bx-trash"></i></button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="4" style="text-align: center;">No announcements available</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- NEW: EXAMS SECTION -->
  <div id="updates" class="content-section" style="display: none;">
    <div class="dashboard admin-dashboard" style="display: block; padding-top: 24px;">
      <div class="panel-column" style="width: 100%;">
        <div class="panel">
          <h3 class="panel-title"><i class="bx bx-calendar-event"></i> Update Next Exam</h3>
          <form class="admin-form" id="examForm">
            <div class="input-group">
              <label>Roll No.</label>
              <input type="text" id="exam-roll" placeholder="e.g. 2410991138" required />
            </div>
            <div class="input-group">
              <label>Subject</label>
              <input type="text" id="exam-subject" placeholder="e.g. Data Structures" required />
            </div>
            <div class="input-group">
              <label>Exam Date</label>
              <input type="date" id="exam-date" required />
            </div>
            <div class="input-group">
              <label>Exam Time</label>
              <input type="time" id="exam-time" required />
            </div>
            <button type="submit" class="btn-primary">
              <i class="bx bx-save"></i> Update Exam
            </button>
            <p id="exam-form-msg" style="margin-top: 10px; color: #4CAF50; font-weight: bold;"></p>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- NEW: CLASSES & EVENTS SECTION -->
  <div id="classes" class="content-section" style="display: none;">
    <div class="dashboard admin-dashboard" style="display: block; padding-top: 24px;">
      <div class="panel-column">
        <div class="panel">
          <h3 class="panel-title"><i class="bx bx-time"></i> Update Next Class</h3>
          <form class="admin-form" id="classForm">
            <div class="input-group">
              <label>Roll No.</label>
              <input type="text" id="class-roll" placeholder="e.g. 2410991138" required />
            </div>
            <div class="input-group">
              <label>Subject</label>
              <input type="text" id="class-subject" placeholder="e.g. Data Structures" required />
            </div>
            <div class="input-group">
              <label>Professor Name</label>
              <input type="text" id="class-professor" placeholder="e.g. Dr. John Smith" required />
            </div>
            <div class="input-group">
              <label>Room No.</label>
              <input type="text" id="class-room" placeholder="e.g. A-201" required />
            </div>
            <div class="input-group">
              <label>Class Date</label>
              <input type="date" id="class-date" required />
            </div>
            <div class="input-group">
              <label>Class Time</label>
              <input type="time" id="class-time" required />
            </div>
            <button type="submit" class="btn-primary">
              <i class="bx bx-save"></i> Update Class
            </button>
            <p id="class-form-msg" style="margin-top: 10px; color: #4CAF50; font-weight: bold;"></p>
          </form>
        </div>
      </div>

      <div class="panel-column">
        <div class="panel">
          <h3 class="panel-title"><i class="bx bx-party"></i> Add Club & Co-Curricular Events</h3>
          <form class="admin-form" id="eventForm">
            <div class="input-group">
              <label>Roll No.</label>
              <input type="text" id="event-roll" placeholder="e.g. 2410991138" required />
            </div>
            <div class="input-group">
              <label>Event Name</label>
              <input type="text" id="event-name" placeholder="e.g. Coding Contest" required />
            </div>
            <div class="input-group">
              <label>Club Name</label>
              <input type="text" id="event-club" placeholder="e.g. Computer Science Club" required />
            </div>
            <div class="input-group">
              <label>Event Date</label>
              <input type="date" id="event-date" required />
            </div>
            <div class="input-group">
              <label>Venue</label>
              <input type="text" id="event-venue" placeholder="e.g. Main Auditorium" required />
            </div>
            <button type="submit" class="btn-primary">
              <i class="bx bx-save"></i> Add Event
            </button>
            <p id="event-form-msg" style="margin-top: 10px; color: #4CAF50; font-weight: bold;"></p>
          </form>
        </div>
      </div>
    </div>
  </div>
  </div>
</div>

<!-- ADD SUBJECT MODAL -->
<div id="addSubjectModal" class="modal-overlay">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title"><i class="bx bx-book modal-icon"></i> Add New Subject</h3>
      <button class="modal-close-btn" onclick="closeModal()"><i class="bx bx-x"></i></button>
    </div>
    <form id="addSubjectForm" class="admin-form">
      <div class="input-group">
        <label>Course Code</label>
        <input type="text" id="subCode" placeholder="e.g. CS101" required>
      </div>
      <div class="input-group">
        <label>Course Name</label>
        <input type="text" id="subName" placeholder="e.g. Introduction to CS" required>
      </div>
      <div class="input-group">
        <label>Credits</label>
        <input type="number" id="subCredits" placeholder="e.g. 4" required>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn-cancel" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn-save">Add Subject</button>
      </div>
    </form>
  </div>
</div>

<!-- ADD/UPDATE RESULT MODAL -->
<div id="addResultModal" class="modal-overlay">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title"><i class="bx bx-edit modal-icon"></i> Update Student Result</h3>
      <button class="modal-close-btn" onclick="closeResultModal()"><i class="bx bx-x"></i></button>
    </div>
    <form id="resultsForm" class="admin-form">
      <div class="input-group">
        <label>Roll No.</label>
        <input type="text" id="res-roll" placeholder="e.g. 2410991138" required />
      </div>
      <div class="input-group">
        <label>Semester</label>
        <input type="number" id="res-sem" placeholder="e.g. 2" required />
      </div>
      <div class="input-group">
        <label>Subject</label>
        <select id="res-subject" class="subject-select" required>
          <option value="">Select Subject</option>
          <% if (typeof subjects !== 'undefined' && subjects.length > 0) { %>
            <% subjects.forEach(sub => { %>
              <option value="<%= sub.name %>"><%= sub.name %></option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <div class="input-group">
        <label>Marks</label>
        <input type="number" id="res-marks" placeholder="85" required />
      </div>
      <div class="input-group">
        <label>Grade</label>
        <input type="text" id="res-grade" placeholder="e.g. A+" required />
      </div>
      <div class="modal-actions">
        <button type="button" class="btn-cancel" onclick="closeResultModal()">Cancel</button>
        <button type="submit" class="btn-save">Save Result</button>
      </div>
      <p id="res-form-msg" style="margin-top: 10px; color: #4CAF50; font-weight: bold;"></p>
    </form>
  </div>
</div>

<!-- ADD ANNOUNCEMENT MODAL -->
<div id="addAnnouncementModal" class="modal-overlay">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title"><i class="bx bx-bell modal-icon"></i> Add New Announcement</h3>
      <button class="modal-close-btn" onclick="closeAnnouncementModal()"><i class="bx bx-x"></i></button>
    </div>
    <form id="addAnnouncementForm" class="admin-form">
      <div class="input-group">
        <label>Title</label>
        <input type="text" id="annTitle" placeholder="e.g. Holiday Notice" required>
      </div>
      <div class="input-group">
        <label>Content</label>
        <textarea id="annText" placeholder="Announcement details..." required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 8px; min-height: 80px;"></textarea>
      </div>
      <div class="input-group">
        <label>Time</label>
        <input type="text" id="annTime" placeholder="e.g. Oct 25, 10:00 AM" required>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn-cancel" onclick="closeAnnouncementModal()">Cancel</button>
        <button type="submit" class="btn-save">Add Announcement</button>
      </div>
    </form>
  </div>
</div>

          <script>
            function switchTab(tabId) {
              document.querySelectorAll('.content-section').forEach(sec => sec.style.display = 'none');
              document.getElementById(tabId).style.display = 'block';
              
              document.getElementById('link-dashboard').classList.remove('active');
              document.getElementById('link-subjects').classList.remove('active');
              document.getElementById('link-results').classList.remove('active');
              if (document.getElementById('link-announcements')) document.getElementById('link-announcements').classList.remove('active');
              if (document.getElementById('link-updates')) document.getElementById('link-updates').classList.remove('active');
              if (document.getElementById('link-classes')) document.getElementById('link-classes').classList.remove('active');
              document.getElementById('link-' + tabId).classList.add('active');
              
              const titles = {
                'dashboard': 'Dashboard Overview',
                'subjects': 'Manage Subjects',
                'results': 'Manage Student Results',
                'announcements': 'Manage Announcements',
                'updates': 'Update Next Exam',
                'classes': 'Manage Classes & Events'
              };
              document.querySelector('.page-title').innerText = titles[tabId] || 'Dashboard Overview';
              localStorage.setItem('adminActiveTab', tabId);
            }

            document.addEventListener("DOMContentLoaded", () => {
                const activeTab = localStorage.getItem('adminActiveTab') || 'dashboard';
                switchTab(activeTab);
            });

            function openModal() {
                document.getElementById('addSubjectModal').style.display = 'flex';
            }

            function closeModal() {
                document.getElementById('addSubjectModal').style.display = 'none';
            }

            function openResultModal() {
                document.getElementById('addResultModal').style.display = 'flex';
                document.getElementById("res-form-msg").innerText = "";
            }

            function closeResultModal() {
                document.getElementById('addResultModal').style.display = 'none';
            }

            function openAnnouncementModal() {
                document.getElementById('addAnnouncementModal').style.display = 'flex';
            }

            function closeAnnouncementModal() {
                document.getElementById('addAnnouncementModal').style.display = 'none';
            }

            document.getElementById('addSubjectForm').addEventListener('submit', async (e) => {
                e.preventDefault();
                const code = document.getElementById('subCode').value;
                const name = document.getElementById('subName').value;
                const credits = document.getElementById('subCredits').value;
                const token = new URLSearchParams(window.location.search).get("token") || localStorage.getItem("token");
                
                try {
                    const res = await fetch('/admin/add-subject', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Authorization': token
                        },
                        body: JSON.stringify({ code, name, credits })
                    });
                    if(res.ok) {
                        window.location.reload();
                    } else {
                        alert("Failed to add subject");
                    }
                } catch(err) {
                    alert("Error adding subject");
                }
            });

            async function deleteSubject(id) {
                if(!confirm("Are you sure you want to delete this subject?")) return;
                const token = new URLSearchParams(window.location.search).get("token") || localStorage.getItem("token");
                try {
                    const res = await fetch('/admin/delete-subject/' + id, {
                        method: 'DELETE',
                        headers: {
                            'Authorization': token
                        }
                    });
                    if(res.ok) {
                        window.location.reload();
                    } else {
                        alert("Failed to delete subject");
                    }
                } catch(err) {
                    alert("Error deleting subject");
                }
            }

            document.getElementById('addAnnouncementForm').addEventListener('submit', async (e) => {
                e.preventDefault();
                const title = document.getElementById('annTitle').value;
                const text = document.getElementById('annText').value;
                const time = document.getElementById('annTime').value;
                const token = new URLSearchParams(window.location.search).get("token") || localStorage.getItem("token");
                
                try {
                    const res = await fetch('/admin/add-announcement', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Authorization': token
                        },
                        body: JSON.stringify({ title, text, time })
                    });
                    if(res.ok) {
                        window.location.reload();
                    } else {
                        alert("Failed to add announcement");
                    }
                } catch(err) {
                    alert("Error adding announcement");
                }
            });

            async function deleteAnnouncement(id) {
                if(!confirm("Are you sure you want to delete this announcement?")) return;
                const token = new URLSearchParams(window.location.search).get("token") || localStorage.getItem("token");
                try {
                    const res = await fetch('/admin/delete-announcement/' + id, {
                        method: 'DELETE',
                        headers: {
                            'Authorization': token
                        }
                    });
                    if(res.ok) {
                        window.location.reload();
                    } else {
                        alert("Failed to delete announcement");
                    }
                } catch(err) {
                    alert("Error deleting announcement");
                }
            }

            function toggleSidebar() {
              document.getElementById("sidebar").classList.toggle("hide");
              document.getElementById("app").classList.toggle("hide-sidebar");
            }
            const attendanceStats = <%- JSON.stringify(attendanceStats) %>;

            const ctx = document.getElementById('attendanceChart').getContext('2d');
            let attendanceChart;

            function renderChart(type, labels, data) {
              if (attendanceChart) {
                attendanceChart.destroy();
              }

              const isBar = type === 'bar';
              attendanceChart = new Chart(ctx, {
                type: type,
                data: {
                  labels: labels,
                  datasets: [{
                    label: 'Average Attendance %',
                    data: data,
                    borderColor: '#7fb2d4',
                    backgroundColor: isBar ? '#7fb2d4' : 'rgba(127, 178, 212, 0.1)',
                    borderWidth: 3,
                    tension: 0.4,
                    fill: !isBar
                  }]
                },
                options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  plugins: {
                    legend: { display: false }
                  },
                  scales: {
                    y: {
                      beginAtZero: true,
                      min: 0,
                      max: 100
                    }
                  }
                }
              });
            }

            // Initial render
            renderChart('bar', attendanceStats.subjects.labels, attendanceStats.subjects.data);

            document.getElementById('attendanceFilter').addEventListener('change', function() {
              const filterType = this.value;
              let labels = [];
              let data = [];

              if (filterType === 'weekly') {
                labels = attendanceStats.weekly.labels;
                data = attendanceStats.weekly.data;
              } else if (filterType === 'monthly') {
                labels = attendanceStats.monthly.labels;
                data = attendanceStats.monthly.data;
              } else if (filterType === 'semester') {
                labels = attendanceStats.subjects.labels;
                data = attendanceStats.subjects.data;
              }

              renderChart('bar', labels, data);
            });
          </script>
          <script>

            document.getElementById("attendanceForm").addEventListener("submit", async (e) => {
              e.preventDefault();
              const roll = document.getElementById("roll").value;
              const subject = document.getElementById("subjectselect").value;
              const percent = document.getElementById("percent").value;

              const token = new URLSearchParams(window.location.search).get("token") || localStorage.getItem("token");

              const msgEl = document.getElementById("form-msg");
              msgEl.innerText = "Saving...";
              msgEl.style.color = "#4a6cf7";

              try {
                const res = await fetch("/admin/update-attendance", {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/json",
                    "Authorization": token
                  },
                  body: JSON.stringify({ roll, subject, percent })
                });
                const data = await res.text();
                if (res.ok) {
                  msgEl.style.color = "#4CAF50";
                  msgEl.innerText = "✓ " + data;
                  document.getElementById("attendanceForm").reset();
                  setTimeout(() => window.location.reload(), 1000);
                } else {
                  msgEl.style.color = "#e02424";
                  msgEl.innerText = "✗ " + data;
                }
              } catch(err) {
                msgEl.style.color = "#e02424";
                msgEl.innerText = "✗ Error updating attendance";
              }
            });

            document.getElementById("resultsForm").addEventListener("submit", async (e) => {
              e.preventDefault();
              const roll = document.getElementById("res-roll").value;
              const subject = document.getElementById("res-subject").value;
              const sem = document.getElementById("res-sem").value;
              const marks = document.getElementById("res-marks").value;
              const grade = document.getElementById("res-grade").value;

              const token = new URLSearchParams(window.location.search).get("token") || localStorage.getItem("token");

              const msgEl = document.getElementById("res-form-msg");
              msgEl.innerText = "Saving...";
              msgEl.style.color = "#4a6cf7";

              try {
                const res = await fetch("/admin/update-results", {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/json",
                    "Authorization": token
                  },
                  body: JSON.stringify({ roll, subject, sem, marks, grade })
                });
                
                if(res.ok) {
                    msgEl.style.color = "#4CAF50";
                    msgEl.innerText = "✓ Result saved successfully!";
                    document.getElementById("resultsForm").reset();
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    const data = await res.text();
                    msgEl.style.color = "#e02424";
                    msgEl.innerText = "✗ " + data;
                }
              } catch(err) {
                  msgEl.style.color = "#e02424";
                  msgEl.innerText = "✗ Error saving result";
              }
            });

            async function deleteResult(dashId, resultId) {
                if(!confirm("Are you sure you want to delete this result?")) return;
                const token = new URLSearchParams(window.location.search).get("token") || localStorage.getItem("token");
                try {
                    const res = await fetch(`/admin/delete-result/${dashId}/${resultId}`, {
                        method: 'DELETE',
                        headers: {
                            'Authorization': token
                        }
                    });
                    if(res.ok) {
                        window.location.reload();
                    } else {
                        alert("Failed to delete result");
                    }
                } catch(err) {
                    alert("Error deleting result");
                }
            }

