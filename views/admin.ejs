              const event = document.getElementById("event-name").value;
              const club = document.getElementById("event-club").value;
              const date = document.getElementById("event-date").value;
              const venue = document.getElementById("event-venue").value;
              const token = new URLSearchParams(window.location.search).get("token") || localStorage.getItem("token");

              try {
                const res = await fetch("/admin/add-event", {
                  method: "POST",
