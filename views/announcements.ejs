<!DOCTYPE html>
<html>

<head>
    <title>Announcements - StudentSpace</title>
    <style>
        body {
            margin: 0;
            font-family: "Segoe UI", sans-serif;
            background: #f4f7fb;
        }

        .container {
            display: flex;
            min-height: 100vh;
        }

        /* SIDEBAR (MATCH DASHBOARD) */
        .sidebar {
            background: #eef5fb;
            padding: 26px 18px;
            border-right: 1px solid #dce8f4;
            width: 250px;
        }

        .sidebar.hide {
            width: 0;
            padding: 0;
            overflow: hidden;
        }

        .sidebar h2 {
            margin: 0 0 26px;
            font-size: 20px;
            font-weight: 700;
            color: #4f8fb8;
        }

        .menu-title {
            font-size: 12px;
            font-weight: 700;
            letter-spacing: .05em;
            color: #6b7280;
            margin: 24px 0 10px 10px;
        }

        .menu a {
            display: block;
            padding: 12px 16px;
            border-radius: 16px;
            color: #334155;
            text-decoration: none;
            margin-bottom: 8px;
            font-size: 15px;
        }

        .menu a:hover {
            background: #ddebf6;
        }

        .menu a.active {
            background: #cfe3f2;
            font-weight: 600;
        }

        /* MAIN */
        .main {
            flex: 1;
            padding: 30px;
        }

        .title {
            font-size: 26px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        /* CARD STYLE */
        .card {
            background: white;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
            margin-bottom: 20px;
        }

        .announcement-item {
            padding: 20px 0;
            border-bottom: 1px solid #eee;
        }

        .announcement-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .announcement-item:first-child {
            padding-top: 0;
        }

        .announcement-title {
            font-size: 18px;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 8px;
        }

        .announcement-time {
            font-size: 13px;
            color: #6b7280;
            margin-bottom: 12px;
            font-weight: 500;
        }

        .announcement-text {
            font-size: 15px;
            color: #4b5563;
            line-height: 1.6;
        }
    </style>
</head>

<body>

    <div class="container">

        <!-- SIDEBAR -->
        <div class="sidebar" id="sidebar">
            <h2>MyStudentSpace</h2>

            <div class="menu">
                <a href="/dashboard/<%= userId %>?token=<%= token %>">Dashboard</a>
                <a href="/profile.html">My Profile</a>

                <div class="menu-title">ACADEMICS</div>
                <a href="/subjects/<%= userId %>?token=<%= token %>">Subjects</a>
                <a href="/results/<%= userId %>?token=<%= token %>">Results</a>
                
                <div class="menu-title">COMMUNICATION</div>
                <a class="active" href="/announcements/<%= userId %>?token=<%= token %>">Announcements</a>
                
                <a href="/announcements/<%= userId %>?token=<%= token %>">Messages</a>

            </div>
        </div>

        <!-- MAIN CONTENT -->
        <div class="main">

            <div class="title">Faculty Announcements</div>

            <div class="card">
                <% if (typeof announcements !== 'undefined' && announcements.length > 0) { %>
                    <% announcements.forEach(function(ann) { %>
                        <div class="announcement-item">
                            <div class="announcement-title"><%= ann.title %></div>
                            <div class="announcement-time"><%= ann.time %></div>
                            <div class="announcement-text"><%= ann.text %></div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p style="color: #6b7280; text-align: center; padding: 20px 0;">No announcements available</p>
                <% } %>
            </div>

        </div>

    </div>

</body>

</html>
